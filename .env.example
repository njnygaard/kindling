# Copy to .env on tatajuba and fill in real values.
# Do not commit .env.

# OpenWeatherMap API key used by the Go renderer.
OPENWEATHERMAP_API_KEY=

# Terminus login for http://192.168.0.182:2300 / trmnl-byos.
TERMINUS_LOGIN=
TERMINUS_PASSWORD=

# Defaults match the OG TRMNL playlist currently used by apartment-ops/photo-gallery.
TERMINUS_URL=http://host.docker.internal:2300
SCREEN_NAME=kindling_weather
SCREEN_LABEL=Kindling Weather
MODEL_ID=1
PLAYLIST_ID=3
INTERVAL_SECONDS=300
TZ=America/Los_Angeles
